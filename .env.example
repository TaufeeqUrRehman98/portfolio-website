# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_change_this_before_deploy

# ─── Admin Credentials ────────────────────────────────────
# Password must be min 12 chars, uppercase, number, special char
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=run_node_scripts/hashPassword.js_to_generate

# ─── Session ──────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30

# ─── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=./assets/images
DOCS_PATH=./assets/docs

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:3000
